component MainComponent(props: Props) {
const title = "Hello";
const items = ["a", "b", "c"];
const isVisible = true;
----
<Column>
  <Text value={title} size="lg" />
  <if condition={isVisible}>
    <Row>
      <each collection={items} as="item">
        <Text value={item} size="sm" />
      </each>
    </Row>
  </if>
</Column>
}
